<%- include('partials/header') %>

<div class="row mb-4 align-items-center">
    <div class="col-md-6">
        <h2 class="fw-bold mb-0">Book Collection</h2>
    </div>
    <div class="col-md-6 d-flex gap-2">
        <div class="input-group shadow-sm rounded-pill overflow-hidden flex-grow-1">
            <input type="text" class="form-control border-0 py-3 ps-4" id="book-search-input" placeholder="Search by title, author, or ISBN...">
            <button class="btn btn-primary px-4" type="button" id="book-search-btn">
                <i class="fas fa-search"></i>
            </button>
        </div>
        <select class="form-select border-0 shadow-sm rounded-pill px-4" id="availability-filter" style="width: auto; min-width: 150px;">
            <option value="all">All Books</option>
            <option value="true">Available</option>
            <option value="false">Out of Stock</option>
        </select>
    </div>
</div>

<div id="alert-container"></div>

<div class="row g-4" id="books-container">
    <div class="col-12 text-center py-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
        <p class="mt-2 text-muted">Loading books...</p>
    </div>
</div>

<!-- Book Issue/Return Modal -->
<div class="modal fade" id="bookModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 rounded-4 shadow">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold" id="modal-title">Book Details</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4" id="modal-content">
                <!-- Content populated by JS -->
            </div>
            <div class="modal-footer border-0 pt-0" id="modal-footer">
                <!-- Buttons populated by JS -->
            </div>
        </div>
    </div>
</div>

<script src="/js/books.js"></script>
<%- include('partials/footer') %>
