<%- include('partials/header') %>

<div class="row mb-4">
    <div class="col-md-12">
        <h2 class="fw-bold">Suppliers Management</h2>
    </div>
</div>

<div id="alert-container"></div>

<div class="card border-0 shadow-sm rounded-4 overflow-hidden">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="bg-light">
                <tr>
                    <th class="px-4 py-3">Supplier Name</th>
                    <th class="py-3">Contact</th>
                    <th class="py-3">Email</th>
                    <th class="py-3">Address</th>
                </tr>
            </thead>
            <tbody id="suppliers-body">
                <tr>
                    <td colspan="4" class="text-center py-5 text-muted">Loading suppliers...</td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', async () => {
    try {
        const suppliers = await apiRequest('/api/suppliers');
        const body = document.getElementById('suppliers-body');
        if (!suppliers || suppliers.length === 0) {
            body.innerHTML = '<tr><td colspan="4" class="text-center py-5">No suppliers found.</td></tr>';
            return;
        }
        body.innerHTML = suppliers.map(s => `
            <tr>
                <td class="px-4 py-3 fw-bold">${s.name}</td>
                <td class="py-3">${s.contactPerson}</td>
                <td class="py-3">${s.email}</td>
                <td class="py-3">${s.address}</td>
            </tr>
        `).join('');
    } catch (err) {
        showAlert(err.message);
    }
});
</script>
<%- include('partials/footer') %>
