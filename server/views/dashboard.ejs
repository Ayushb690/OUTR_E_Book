<%- include('partials/header') %>

<div class="row mb-4">
    <div class="col-md-12">
        <div class="card bg-primary text-white shadow-sm border-0 rounded-4 overflow-hidden">
            <div class="card-body p-5">
                <div class="row align-items-center">
                    <div class="col-md-8">
                        <h1 class="display-4 fw-bold">Welcome, <span id="user-name">User</span>!</h1>
                        <p class="lead mb-0">Manage your library activities and explore new books today.</p>
                    </div>
                    <div class="col-md-4 text-end d-none d-md-block">
                        <i class="fas fa-university fa-5x opacity-25"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mb-5" id="librarian-stats" style="display: none;">
    <div class="col-md-3">
        <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-body text-center p-4">
                <div class="text-primary mb-3">
                    <i class="fas fa-book-open fs-1"></i>
                </div>
                <h5 class="text-muted mb-1">Total Books</h5>
                <h2 class="fw-bold" id="stat-total-books">-</h2>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-body text-center p-4">
                <div class="text-success mb-3">
                    <i class="fas fa-users fs-1"></i>
                </div>
                <h5 class="text-muted mb-1">Total Members</h5>
                <h2 class="fw-bold" id="stat-total-users">-</h2>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-body text-center p-4">
                <div class="text-warning mb-3">
                    <i class="fas fa-shopping-cart fs-1"></i>
                </div>
                <h5 class="text-muted mb-1">Purchase Orders</h5>
                <h2 class="fw-bold" id="stat-total-pos">-</h2>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-body text-center p-4">
                <div class="text-danger mb-3">
                    <i class="fas fa-exclamation-triangle fs-1"></i>
                </div>
                <h5 class="text-muted mb-1">Damaged Books</h5>
                <h2 class="fw-bold" id="stat-damaged">-</h2>
            </div>
        </div>
    </div>
</div>

<div class="row g-4" id="student-content" style="display: none;">
    <div class="col-md-6">
        <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-header bg-transparent border-0 pt-4 px-4">
                <h4 class="fw-bold mb-0 text-primary">My Active Issues</h4>
            </div>
            <div class="card-body p-4">
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead>
                            <tr>
                                <th>Book</th>
                                <th>Due Date</th>
                                <th>Fine</th>
                            </tr>
                        </thead>
                        <tbody id="active-issues-body">
                            <tr><td colspan="3" class="text-center py-3">No active issues.</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-header bg-transparent border-0 pt-4 px-4">
                <h4 class="fw-bold mb-0 text-success">My Recent Requests</h4>
            </div>
            <div class="card-body p-4">
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead>
                            <tr>
                                <th>Book</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody id="recent-requests-body">
                            <tr><td colspan="2" class="text-center py-3">No recent requests.</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mt-2">
    <div class="col-md-8">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-header bg-transparent border-0 pt-4 px-4 d-flex justify-content-between align-items-center">
                <h4 class="fw-bold mb-0">Quick Actions</h4>
            </div>
            <div class="card-body p-4">
                <div class="row g-3">
                    <div class="col-6 col-md-4">
                        <a href="/books" class="btn btn-outline-primary w-100 py-3 rounded-4">
                            <i class="fas fa-search d-block mb-2 fs-4"></i> Search Books
                        </a>
                    </div>
                    <div class="col-6 col-md-4 librarian-action" style="display: none;">
                        <a href="/suppliers" class="btn btn-outline-success w-100 py-3 rounded-4">
                            <i class="fas fa-truck d-block mb-2 fs-4"></i> Suppliers
                        </a>
                    </div>
                    <div class="col-6 col-md-4 librarian-action" style="display: none;">
                        <a href="/reports" class="btn btn-outline-info w-100 py-3 rounded-4">
                            <i class="fas fa-file-alt d-block mb-2 fs-4"></i> Reports
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-header bg-transparent border-0 pt-4 px-4">
                <h4 class="fw-bold mb-0">My Profile</h4>
            </div>
            <div class="card-body p-4">
                <div class="d-flex align-items-center mb-3">
                    <div class="bg-primary text-white rounded-circle p-3 me-3">
                        <i class="fas fa-user-circle fs-2"></i>
                    </div>
                    <div>
                        <h5 class="mb-0 fw-bold" id="profile-name">-</h5>
                        <p class="text-muted mb-0" id="profile-role">-</p>
                    </div>
                </div>
                <ul class="list-group list-group-flush mt-3">
                    <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                        Email <span class="fw-bold" id="profile-email">-</span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                        Member ID <span class="fw-bold" id="profile-id">-</span>
                    </li>
                </ul>
            </div>
        </div>
    </div>
</div>

<script src="/js/dashboard.js"></script>
<%- include('partials/footer') %>
